---
const features = [
  {
    emoji: '🦎',
    tag: 'Colección',
    title: 'Xacobitos',
    desc: 'Descubre y colecciona criaturas míticas de la tradición gallega mientras caminas. Cada etapa esconde nuevas sorpresas que enriquecen tu aventura.',
  },
  {
    emoji: '🗺️',
    tag: 'Navegación',
    title: 'Itinerario Vivo',
    desc: 'Mapas dinámicos con información de cada etapa, puntos de interés, albergues y hitos históricos del Camino actualizados en tiempo real.',
  },
  {
    emoji: '🏕️',
    tag: 'Diario',
    title: 'Mochila',
    desc: 'Tu diario digital de peregrino. Guarda fotos, emociones y recuerdos de cada día. Revive tu viaje etapa a etapa cuando el Camino quede atrás.',
  },
  {
    emoji: '🐱',
    tag: 'Guía',
    title: 'Gaticonsejos',
    desc: 'Santi, tu compañero felino del Camino, te da consejos prácticos, curiosidades históricas y motivación personalizada a lo largo del trayecto.',
  },
  {
    emoji: '👥',
    tag: 'Comunidad',
    title: 'Social Peregrino',
    desc: 'Conecta con otros peregrinos en ruta, comparte tu progreso, comenta experiencias y forma parte de una comunidad global unida por el Camino.',
  },
  {
    emoji: '🎖️',
    tag: 'Progreso',
    title: 'Progresión RPG',
    desc: 'Sube de nivel, desbloquea logros y obtén recompensas únicas según tus kilómetros, etapas completadas y misiones especiales del Camino.',
  },
];
---

<section id="section-funciones" class="features-section">
  <div class="features-inner">
    <div class="features-header gs-reveal">
      <h2 class="features-title">Todo lo que necesitas<br />para vivir el Camino</h2>
      <p class="features-subtitle">Seis formas de hacer tu peregrinación más rica, conectada y memorable</p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <article class="feature-card">
          <div class="card-top-bar" aria-hidden="true"></div>
          <div class="card-emoji" aria-hidden="true">{f.emoji}</div>
          <span class="card-tag">{f.tag}</span>
          <h3 class="card-title">{f.title}</h3>
          <p class="card-desc">{f.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: #0a2516;
    padding: 100px 28px;
  }
  .features-inner {
    max-width: 1160px;
    margin: 0 auto;
  }
  .features-header {
    text-align: center;
    margin-bottom: 64px;
  }
  .features-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(32px, 4vw, 50px);
    color: #fff;
    line-height: 1.08;
    margin-bottom: 16px;
  }
  .features-subtitle {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    color: #ffe100;
    opacity: 0.9;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .feature-card {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 32px 28px 28px;
    overflow: hidden;
    transition: transform 280ms ease, box-shadow 280ms ease, border-color 280ms ease;
  }
  .card-top-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #ffe100;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 300ms ease;
  }
  .feature-card:hover .card-top-bar {
    transform: scaleX(1);
  }
  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 225, 0, 0.38);
  }
  .card-emoji {
    font-size: 48px;
    line-height: 1;
    display: block;
    margin-bottom: 16px;
  }
  .card-tag {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #ffe100;
    display: block;
    margin-bottom: 8px;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 30px;
    color: #fff;
    margin-bottom: 12px;
    line-height: 1.1;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .features-section { padding: 72px 20px; }
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
